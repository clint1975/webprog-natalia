{
  "name": "natalia-webprog",
  "private": true,
  "version": "1.0.0",
  "description": "Natalia Creative Lab - web application",
  "workspaces": [
    "natalia-client",
    "natalia-server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace natalia-client",
    "dev:server": "npm run dev --workspace natalia-server",
    "build:client": "npm run build --workspace natalia-client",
    "build:server": "npm run build --workspace natalia-server",
    "vercel-build": "npm --prefix natalia-client run build"
  }
}
